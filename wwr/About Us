  <style>
    body {
      font-family: 'Open Sans', sans-serif;
      margin: 0;
      padding: 0;
    }

    .header-container {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      padding: 1em;
      background-color: #396e94;
      color: white;
    }

    .logo {
      width: 50px;
      height: 50px;
    }

    header nav {
      display: flex;
      gap: 1em;
    }

    header nav a {
      color: white;
      text-decoration: none;
    }

    header nav a:hover {
      text-decoration: underline;
    }

    main {
      padding: 1em;
      max-width: 1200px;
      margin: auto;
    }

    .about-section {
      margin-bottom: 2em;
    }

    .team-member {
      display: flex;
      align-items: center;
      margin-bottom: 1.5em;
    }

    .team-member img {
      border-radius: 50%;
      width: 100px;
      height: 100px;
      margin-right: 1em;
    }

    .team-member h3 {
      margin: 0;
    }

    .adventures {
      display: flex;
      flex-wrap: wrap;
      gap: 1em;
    }

    .adventures figure {
      flex: 1;
      text-align: center;
    }

    footer {
      background-color: #396e94;
      color: white;
      padding: 1em;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .footer-container {
      display: flex;
      justify-content: space-between;
      width: 100%;
